# =========================================
# AgentForge — Sevalla Environment Variables
# =========================================
# Set these as Sevalla secrets in the app dashboard.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=generate-a-strong-random-string-here

# --- Optional (Gemini model support) ---
GOOGLE_API_KEY=

# --- Optional (Slack notifications) ---
SLACK_BOT_TOKEN=

# --- Optional (n8n integration) ---
N8N_BASE_URL=
N8N_API_KEY=

# --- Optional (override CORS — defaults to wildcard) ---
# SEVALLA_URL=https://your-app.sevalla.app

# --- Optional (external PostgreSQL — if not set, embedded PG is used) ---
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# DB_HOST=host
# DB_USER=user
# DB_NAME=dbname
# DB_PASSWORD=pass

# --- App settings ---
ENVIRONMENT=production
